{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@main/*": ["src/main/*"],
      "@infra/*": ["src/infrastructure/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "eslint.config.js",
    "src/main",
    "src/preload",
    "src/shared",
    "src/infrastructure",
    "tests",
    "tailwind.config.ts",
    "postcss.config.cjs"
  ],
  "exclude": ["tests/renderer"]
}
