{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "QA: Full Validation Suite",
      "type": "shell",
      "command": "npm run qa",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: Unit + Integration",
      "type": "shell",
      "command": "npm test",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: E2E (authenticated)",
      "type": "shell",
      "command": "npm run test:e2e:auth",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: E2E debug (headed)",
      "type": "shell",
      "command": "COPILOT_AUTHENTICATED=1 npx playwright test tests/e2e/debug-new-chat.e2e.ts --headed",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
